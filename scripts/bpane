#!/usr/bin/env sh
set -eu

if ! command -v node >/dev/null 2>&1; then
  echo "BrowserPane CLI requires node on PATH." >&2
  exit 127
fi

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)

exec node "$repo_root/code/web/bpane-client/scripts/bpane-cli.mjs" "$@"
