# BrowserPane Web Frontend
# Stage 1: Build the bpane-client SDK
FROM node:22-alpine AS build
WORKDIR /app
COPY code/web/bpane-client/package.json code/web/bpane-client/package-lock.json* ./
RUN npm ci
COPY code/web/bpane-client/ ./
RUN npm run build

# Stage 2: Build the bpane-admin console
FROM node:22-alpine AS build-admin
WORKDIR /admin
ENV BPANE_ADMIN_BASE_PATH=/admin
COPY code/web/bpane-admin/package.json code/web/bpane-admin/package-lock.json* ./
RUN npm ci
COPY code/web/bpane-admin/ ./
RUN npm run build

# Stage 3: Serve via nginx
FROM nginx:alpine
RUN rm /etc/nginx/conf.d/default.conf
RUN apk add --no-cache gettext openssl
COPY deploy/nginx.conf /etc/nginx/conf.d/bpane.conf
COPY deploy/web-cert-metadata.sh /docker-entrypoint.d/20-web-cert-metadata.sh
COPY deploy/web-auth-config.sh /docker-entrypoint.d/30-web-auth-config.sh
RUN chmod +x /docker-entrypoint.d/20-web-cert-metadata.sh
RUN chmod +x /docker-entrypoint.d/30-web-auth-config.sh
COPY dev/web-fixtures/index.html /usr/share/nginx/html/index.html
COPY dev/web-fixtures/test-embed.html /usr/share/nginx/html/test-embed.html
COPY dev/web-fixtures/benchmark-scroll.html /usr/share/nginx/html/benchmark-scroll.html
COPY dev/web-fixtures/benchmark-article.html /usr/share/nginx/html/benchmark-article.html
COPY dev/web-fixtures/workflow-credential-fixture.html /usr/share/nginx/html/workflow-credential-fixture.html
COPY dev/web-fixtures/workflow-extension-fixture.html /usr/share/nginx/html/workflow-extension-fixture.html
COPY dev/web-fixtures/auth-config.template.json /usr/share/nginx/html/auth-config.template.json
COPY --from=build /app/dist/ /usr/share/nginx/html/dist/
COPY --from=build-admin /admin/build/ /usr/share/nginx/html/admin/

EXPOSE 8080
