# BrowserPane Web Frontend
# Stage 1: Build the bpane-client SDK
FROM node:22-alpine AS build
WORKDIR /app
COPY code/web/bpane-client/package.json code/web/bpane-client/package-lock.json* ./
RUN npm ci
COPY code/web/bpane-client/ ./
RUN npm run build

# Stage 2: Serve via nginx
FROM nginx:alpine
RUN rm /etc/nginx/conf.d/default.conf
COPY deploy/nginx.conf /etc/nginx/conf.d/bpane.conf
COPY dev/test-embed.html /usr/share/nginx/html/index.html
COPY dev/benchmark-scroll.html /usr/share/nginx/html/benchmark-scroll.html
COPY --from=build /app/dist/ /usr/share/nginx/html/dist/

# The token file will be mounted at /usr/share/nginx/html/token
# by the compose volume from the gateway container.

EXPOSE 8080
