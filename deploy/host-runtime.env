# BrowserPane host runtime defaults shared by:
# - the static `host` service in deploy/compose.yml
# - docker-backed session workers launched by bpane-gateway

BPANE_H264_MODE=video_tiles
BPANE_H264_BITRATE=12M
BPANE_H264_MAXRATE=16M
BPANE_H264_BUFSIZE=6M
BPANE_H264_PRESET=ultrafast
BPANE_H264_PROFILE=baseline
BPANE_H264_LEVEL=4.2
BPANE_H264_TUNE=zerolatency
BPANE_H264_BFRAMES=0
BPANE_FPS=60

BPANE_CDP_MIN_VIDEO_WIDTH=480
BPANE_CDP_MIN_VIDEO_HEIGHT=270
BPANE_CDP_MIN_VIDEO_AREA_RATIO=0.12
BPANE_CDP_PAUSE_VIDEOS_ON_SCROLL=true
BPANE_CDP_SCROLL_PAUSE_WINDOW_MS=900
BPANE_VIDEO_CLICK_ARM_MS=8000

BPANE_AUDIO_CODEC=opus
BPANE_TILE_CODEC=zstd

RUST_LOG=info,bpane_host=debug
BPANE_URL=https://news.google.com/home?hl=en-US&gl=US&ceid=US:en

BPANE_DPI=150
GDK_SCALE=2
GDK_DPI_SCALE=0.8
BPANE_PROFILE_ROOT=/run/bpane/profiles
BPANE_SESSION_ID=static-default
