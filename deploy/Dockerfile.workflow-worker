# BrowserPane Workflow Worker
FROM node:22-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY code/integrations/workflow-worker/package.json code/integrations/workflow-worker/package-lock.json ./
RUN npm ci

COPY code/integrations/workflow-worker/tsconfig.json ./
COPY code/integrations/workflow-worker/src ./src

CMD ["npx", "tsx", "src/index.ts"]
