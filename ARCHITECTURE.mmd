flowchart LR
  classDef actor fill:#fff2d6,stroke:#9a6700,color:#3b2d00,stroke-width:1px;
  classDef browser fill:#e6f4ff,stroke:#1f6feb,color:#0b2540,stroke-width:1px;
  classDef service fill:#eef8ee,stroke:#2f7d32,color:#17351a,stroke-width:1px;
  classDef control fill:#f5ecff,stroke:#8250df,color:#2f1b69,stroke-width:1px;
  classDef runtime fill:#ffeaea,stroke:#cf222e,color:#5a1116,stroke-width:1px;
  classDef storage fill:#f2f2f2,stroke:#57606a,color:#24292f,stroke-width:1px;
  classDef contract fill:#fff8c5,stroke:#9a6700,color:#3b2d00,stroke-width:1px;

  subgraph actors["Actors And Entry Points"]
    direction TB
    browserUser["Interactive browser user"]:::actor
    viewerUser["Additional viewer user"]:::actor
    apiUser["API client / workflow launcher"]:::actor
    mcpClient["External MCP client / AI agent"]:::actor
  end

  subgraph contracts["Shared Contracts"]
    direction TB
    openapi["openapi/bpane-control-v1.yaml<br/>Frozen owner-scoped control-plane contract<br/>sessions, automation-access, recordings,<br/>automation-tasks, workflows, workflow-runs"]:::contract
    protocol["code/shared/bpane-protocol<br/>Binary frame envelope + channel IDs<br/>CH_VIDEO, CH_AUDIO_OUT, CH_AUDIO_IN, CH_VIDEO_IN,<br/>CH_INPUT, CH_CURSOR, CH_CLIPBOARD, CH_FILE_UP,<br/>CH_FILE_DOWN, CH_CONTROL, CH_TILES"]:::contract
  end

  subgraph frontend["Browser And Web Entry"]
    direction TB
    web["web service / nginx<br/>serves test-embed.html, dist, auth-config.json,<br/>cert-fingerprint, same-origin API proxy in local dev"]:::browser
    keycloak["Keycloak<br/>OIDC realm for browser users and service accounts"]:::control

    subgraph browserRuntime["Browser Client Runtime - code/web/bpane-client"]
      direction TB
      browserTab["Browser tab roles<br/>interactive, viewer, recorder"]:::browser
      bpaneSession["BpaneSession + session runtimes<br/>session-control-runtime<br/>session-transport-runtime<br/>session-frame-router-runtime<br/>session-send-runtime"]:::browser
      render["Rendering path<br/>TileCompositor / WebGLCompositor / Canvas fallback<br/>CH_TILES reliable UI path<br/>CH_VIDEO ROI H.264 datagram overlay"]:::browser
      browserIO["Browser-side I/O and media<br/>keyboard, mouse, scroll, clipboard<br/>upload/download, resize<br/>microphone Opus encode, camera H.264 encode<br/>recording runtime"]:::browser
    end
  end

  subgraph gatewayPlane["Gateway And Control Plane - code/apps/bpane-gateway"]
    direction TB
    api["HTTP API :8932<br/>api.rs + auth.rs<br/>owner-scoped bearer auth<br/>session CRUD + access tokens + status<br/>automation-owner + mcp-owner<br/>recordings + playback/export<br/>automation-tasks + workflows + workflow-runs"]:::control
    ticketMgr["Credential managers<br/>connect_ticket.rs<br/>automation_access_token.rs<br/>short-lived session-bound credentials"]:::control
    sessionStore["session_control.rs<br/>persistent resource store facade<br/>session resources + runtime assignments<br/>automation task/workflow state + logs + events"]:::control
    workflowTask["workflow.rs + automation_task.rs<br/>typed workflow definitions and versions<br/>workflow runs, automation tasks, outputs"]:::control
    recordingCtl["recording_lifecycle.rs<br/>recording_playback.rs<br/>recording_retention.rs<br/>recording_observability.rs<br/>segment lifecycle + playback/export generation"]:::control
    transport["WebTransport server :4433<br/>transport.rs<br/>QUIC streams + datagrams<br/>admission via connect ticket or legacy access token"]:::service
    registry["session_registry.rs<br/>hub lifecycle + concurrent join coordination"]:::service
    hub["session_hub.rs<br/>one host-agent connection to N browser clients<br/>owner/viewer/recorder roles<br/>MCP ownership, resolution lock, viewer cap<br/>late-join bootstrap from cached SessionReady/keyframe/grid"]:::service
    sessionManager["session_manager.rs<br/>internal runtime lifecycle facade"]:::service
    runtimeManager["runtime_manager.rs<br/>backends: static_single, docker_single, docker_pool<br/>resolve session_id to runtime socket/CDP endpoint<br/>persist and reconcile runtime assignments<br/>reuse session-scoped Chromium profile path"]:::service
  end

  subgraph integrations["Automation And Worker Integrations"]
    direction TB
    mcpBridge["mcp-bridge - Node.js<br/>SSE server :8931<br/>/control-session + /health<br/>SessionControlClient issues automation-access<br/>claims session-scoped MCP ownership"]:::control
    playwrightMcp["@playwright/mcp subprocess<br/>spawned in STDIO mode by mcp-bridge<br/>tools/resources/prompts proxied to SSE clients"]:::control
    executor["Automation executor / workflow runner<br/>current examples: smoke scripts, Playwright-based runners<br/>connects via automation-access token + CDP endpoint<br/>updates task/run state, logs, outputs"]:::control
    recordingWorker["recording-worker - Node.js<br/>Playwright-driven recorder client<br/>creates/adopts session recording resources<br/>waits for finalization, downloads artifact,<br/>calls complete/fail recording routes"]:::control
  end

  subgraph runtimePlane["Runtime Plane"]
    direction LR
    dockerEngine["Docker Engine + shared /run/bpane volume<br/>used by docker_single and docker_pool backends<br/>mounts session socket roots and Chromium profile state"]:::runtime

    subgraph hostRuntime["Host Runtime Worker - code/apps/bpane-host"]
      direction TB
      host["bpane-host main.rs<br/>SessionReady capability flags<br/>Unix socket agent endpoint"]:::runtime
      capture["capture/ + tiles/<br/>XDamage/XComposite/MIT-SHM capture<br/>hashing, cache hits, fill/QOI/zstd tiles<br/>scroll detection and classification"]:::runtime
      media["audio/, camera.rs, clipboard.rs,<br/>filetransfer.rs, resize.rs, input/<br/>desktop audio out, mic in, camera ingress,<br/>clipboard sync, file transfer, resize, input injection"]:::runtime
      ffmpeg["FFmpeg / PipeWire / socat helpers<br/>x11grab + libx264 ROI/full-frame video<br/>desktop audio capture<br/>CDP proxy and media bridge processes"]:::runtime
      xorg["Xorg dummy + Openbox"]:::runtime
      chromium["Chromium desktop session<br/>real browser state and persistent profile<br/>CDP endpoint exposed to automation"]:::runtime
    end
  end

  subgraph persistence["Persistence And Artifacts"]
    direction TB
    postgres["Postgres<br/>owner-scoped sessions<br/>runtime assignments<br/>recording metadata and playback summaries<br/>automation tasks, workflow definitions/versions,<br/>workflow runs, events, logs, outputs"]:::storage
    artifactStore["RecordingArtifactStore local_fs<br/>opaque artifact refs instead of raw paths<br/>retained recording segments + exported playback bundle"]:::storage
  end

  browserUser -->|"HTTP :8080<br/>load UI, auth config, cert fingerprint"| web
  viewerUser -->|"HTTP :8080<br/>join selected session"| web
  apiUser -->|"HTTP API calls<br/>create/list sessions<br/>create automation tasks/workflows/runs"| api
  mcpClient -->|"MCP over SSE"| mcpBridge

  web -->|"OIDC discovery and redirects"| keycloak
  browserTab -->|"Authorization Code + PKCE"| keycloak
  keycloak -->|"JWTs / client credentials tokens"| api
  keycloak -->|"service-account tokens"| mcpBridge
  keycloak -->|"optional worker auth"| recordingWorker

  web -->|"serves SDK + app shell"| browserTab
  browserTab --> bpaneSession
  bpaneSession --> render
  bpaneSession --> browserIO

  browserTab -->|"owner-scoped /api/v1/*<br/>session selection, status, recordings"| api
  browserTab -->|"PUT /control-session when delegating local MCP bridge"| mcpBridge
  api -->|"POST /api/v1/sessions/{id}/access-tokens<br/>mint session_connect_ticket"| ticketMgr
  ticketMgr -->|"session_connect_ticket"| browserTab
  browserTab -->|"WebTransport :4433<br/>session_ticket + client_role"| transport

  transport --> registry
  registry --> hub
  transport -->|"resolve runtime by session_id"| sessionManager
  sessionManager --> runtimeManager
  runtimeManager -->|"static_single shared socket<br/>or docker_single/docker_pool orchestration"| dockerEngine
  dockerEngine -->|"starts/recovers worker containers<br/>mounts shared /run/bpane volume"| host

  hub -->|"binary Frames over Unix socket<br/>/run/bpane/agent.sock or session socket root"| host
  protocol --> hub
  protocol --> host
  protocol --> bpaneSession

  host --> capture
  host --> media
  host --> ffmpeg
  xorg --> chromium
  chromium --> capture
  chromium --> media
  ffmpeg --> capture
  ffmpeg --> media

  capture -->|"CH_TILES reliable stream<br/>GridConfig, Fill, CacheHit, QOI, Zstd, ScrollCopy"| hub
  ffmpeg -->|"CH_VIDEO datagrams<br/>ROI/full-frame H.264 NAL fragments"| hub
  media -->|"CH_CURSOR / CH_CLIPBOARD / CH_FILE_DOWN<br/>CH_AUDIO_OUT / CH_CONTROL"| hub
  hub -->|"broadcast cached state + live frames"| transport
  transport -->|"streams + datagrams"| bpaneSession
  browserIO -->|"CH_INPUT / CH_CLIPBOARD / CH_FILE_UP<br/>CH_AUDIO_IN Opus / CH_VIDEO_IN H.264<br/>ResolutionRequest / Ping / Pong"| transport

  runtimeManager -->|"persist/reconcile runtime assignments<br/>publish session runtime/CDP metadata"| sessionStore
  api --> sessionStore
  api --> workflowTask
  api --> recordingCtl
  sessionStore --> postgres
  workflowTask --> postgres
  recordingCtl --> postgres
  recordingCtl --> artifactStore

  openapi --> api
  openapi --> mcpBridge
  openapi --> recordingWorker
  openapi --> executor

  mcpBridge -->|"GET/POST /api/v1/sessions<br/>POST /automation-access<br/>POST/DELETE /mcp-owner<br/>GET /status"| api
  mcpBridge -->|"spawn and supervise"| playwrightMcp
  api -->|"automation-access response<br/>CDP endpoint + session_automation_access_token"| mcpBridge
  playwrightMcp -->|"Chrome DevTools Protocol"| chromium

  executor -->|"POST /api/v1/sessions/{id}/automation-access"| api
  api -->|"session_automation_access_token + endpoint_url"| executor
  executor -->|"x-bpane-automation-access-token<br/>task state/logs/events<br/>workflow run state/logs/outputs"| api
  executor -->|"CDP / browser automation attach"| chromium

  recordingWorker -->|"GET session<br/>POST/GET recordings<br/>POST complete/fail"| api
  recordingWorker -.->|"launches Playwright browser page<br/>clientRole=recorder"| browserTab
  api -->|"recording finalization requests / playback export"| recordingWorker
  artifactStore -->|"serve retained segment bytes<br/>build playback zip + manifest"| api
